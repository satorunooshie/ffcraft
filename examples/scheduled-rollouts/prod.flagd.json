{
  "$schema": "https://flagd.dev/schema/v0/flags.json",
  "flags": {
    "new-checkout": {
      "state": "ENABLED",
      "variants": {
        "off": false,
        "on": true
      },
      "defaultVariant": "off",
      "targeting": {
        "if": [
          {
            "\u003e=": [
              {
                "var": "$flagd.timestamp"
              },
              1777626000
            ]
          },
          {
            "if": [
              {
                "==": [
                  {
                    "var": "user.type"
                  },
                  "internal"
                ]
              },
              "on",
              "off"
            ]
          },
          {
            "if": [
              {
                "\u003e=": [
                  {
                    "var": "$flagd.timestamp"
                  },
                  1778230800
                ]
              },
              {
                "if": [
                  {
                    "==": [
                      {
                        "var": "user.type"
                      },
                      "internal"
                    ]
                  },
                  "on",
                  {
                    "if": [
                      {
                        "==": [
                          {
                            "var": "user.segment"
                          },
                          "beta"
                        ]
                      },
                      "on",
                      {
                        "fractional": [
                          {
                            "cat": [
                              {
                                "var": "$flagd.flagKey"
                              },
                              {
                                "var": "targetingKey"
                              }
                            ]
                          },
                          [
                            "off",
                            90
                          ],
                          [
                            "on",
                            10
                          ]
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "if": [
                  {
                    "\u003e=": [
                      {
                        "var": "$flagd.timestamp"
                      },
                      1778835600
                    ]
                  },
                  {
                    "if": [
                      {
                        "==": [
                          {
                            "var": "user.type"
                          },
                          "internal"
                        ]
                      },
                      "on",
                      {
                        "if": [
                          {
                            "==": [
                              {
                                "var": "user.segment"
                              },
                              "beta"
                            ]
                          },
                          "on",
                          {
                            "fractional": [
                              {
                                "cat": [
                                  {
                                    "var": "$flagd.flagKey"
                                  },
                                  {
                                    "var": "targetingKey"
                                  }
                                ]
                              },
                              [
                                "off",
                                50
                              ],
                              [
                                "on",
                                50
                              ]
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "if": [
                      {
                        "\u003e=": [
                          {
                            "var": "$flagd.timestamp"
                          },
                          1779440400
                        ]
                      },
                      "on",
                      "off"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  }
}
